# AI DB Explorer — Environment Variables
# Copy this file to server/.env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# OpenRouter API key — get one free at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# CORS: comma-separated list of allowed origins (used in production)
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Demo Database (optional) ───────────────────────────────────────────────────
# Credentials for the built-in demo database shown to new users.
# Leave blank to disable the "Use Demo DB" button.
DEMO_DB_HOST=your-demo-db-host
DEMO_DB_PORT=5432
DEMO_DB_USER=your-demo-db-user
DEMO_DB_PASSWORD=your-demo-db-password
DEMO_DB_NAME=your-demo-db-name
DEMO_DB_SSL=true
# Optional: extra connection options (e.g. ?options=-c search_path=myschema)
DEMO_DB_OPTIONS=
